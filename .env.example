# ─────────────────────────────────────────────────────────────────────────────
# Linear Clone — Root docker-compose environment
# Copy this file to .env in the project root.
# These variables override defaults in docker-compose.yml.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL container ──────────────────────────────────────────────────────
POSTGRES_USER=linear
POSTGRES_PASSWORD=linear_secret
POSTGRES_DB=linear_clone
POSTGRES_PORT=5432          # host port (change if 5432 is already in use)

# ── Service host ports ────────────────────────────────────────────────────────
BACKEND_PORT=3000           # host port for the API
FRONTEND_PORT=80            # host port for nginx (change to e.g. 8080 if 80 is taken)

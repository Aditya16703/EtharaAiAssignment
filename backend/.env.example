# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"

DATABASE_PASSWORD="<YOUR_SUPABASE_DB_PASSWORD>"
JWT_ACCESS_SECRET="<MIN_32_CHAR_RANDOM_SECRET_FOR_ACCESS_TOKENS>"
JWT_REFRESH_SECRET="<MIN_32_CHAR_RANDOM_SECRET_FOR_REFRESH_TOKENS>"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"
PORT=3000
NODE_ENV="development"

# ── Production extras (set these in Railway / Docker) ────────────────────────
# CORS_ORIGIN="https://yourdomain.com"
# COOKIE_DOMAIN=".yourdomain.com"

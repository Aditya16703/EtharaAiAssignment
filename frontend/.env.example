# ─────────────────────────────────────────────────────────────────────────────
# Linear Clone Frontend — Environment Variables
# Copy to .env.local for local dev, or .env for CI/CD
# All VITE_ prefixed vars are bundled into the JS at build time.
# ─────────────────────────────────────────────────────────────────────────────

# API base URL
# - Local dev (Vite proxy):   leave empty or set to /api
# - Docker (nginx proxy):     /api  (nginx routes /api → backend:3000)
# - Standalone frontend:      http://localhost:3000/api
VITE_API_URL=/api

# App meta
VITE_APP_NAME="Linear Clone"
